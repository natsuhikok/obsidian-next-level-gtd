{
	"name": "obsidian-plugin-dev",
	"version": "1.0.0",
	"description": "Obsidian community plugin boilerplate with i18n and settings.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"check": "npm run lint",
		"lint": "eslint . && tsc -noEmit -skipLibCheck",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.19.15",
		"esbuild": "0.27.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"prettier": "^3.8.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
